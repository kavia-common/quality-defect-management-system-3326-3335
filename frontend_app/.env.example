# Frontend configuration (Create React App requires REACT_APP_ prefix)

# Preferred API base (IMPORTANT: include /api)
# Example: https://<host>:3001/api
REACT_APP_API_BASE=

# Alternative: backend base (frontend will use `${REACT_APP_BACKEND_URL}/api`)
REACT_APP_BACKEND_URL=

# Optional informational URLs
REACT_APP_FRONTEND_URL=
REACT_APP_WS_URL=

# Misc / template vars
REACT_APP_NODE_ENV=development
REACT_APP_LOG_LEVEL=info

# Health check path relative to API base (backend exposes GET /api/health/)
REACT_APP_HEALTHCHECK_PATH=/health/
